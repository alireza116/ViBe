{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    // Declares ImportMeta.env, so the dev guards can reference `import.meta.env.DEV`
    // in the PLAIN form Vite statically recognizes. A JSDoc cast around import.meta
    // hides the reference from Vite's transform, leaving env undefined at runtime and
    // the guards permanently dead.
    "types": ["vite/client"]
  },
  "include": ["src/**/*"]
}
