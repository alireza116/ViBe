{
  "name": "vibe-js",
  "version": "1.0.0",
  "description": "Declarative, grammar-of-graphics-inspired library for interactive visual belief elicitation.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/types.d.ts",
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./dist": {
      "import": "./dist/vibe.js",
      "default": "./dist/vibe.js"
    },
    "./docs-ui": {
      "types": "./docs-next/components/index.ts",
      "import": "./docs-next/components/index.ts",
      "default": "./docs-next/components/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "docs-next",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "dev:docs-next": "next dev docs-next",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "build:docs": "vite build",
    "build:docs-next": "next build docs-next",
    "start:docs-next": "next start docs-next",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:browser": "node scripts/verify-browser.mjs",
    "verify:docs-next": "node scripts/verify-docs-next.mjs",
    "migrate:docs-next": "node scripts/migrate-docs-next.mjs",
    "migrate:examples-to-tsx": "node scripts/migrate-examples-to-tsx.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next": "^15.5.20",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-live": "^4.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
